---
import { FORMSPREE_ID, CONTACT_EMAIL } from '../config';
const formAction = `https://formspree.io/f/${FORMSPREE_ID}`;

// Champ avec icône intégrée (fond blanc, icône qui s'illumine au focus)
const fieldClass =
  'peer w-full pl-11 pr-4 py-3 rounded-xl border border-[var(--color-border)] bg-white ' +
  'text-[var(--color-text)] placeholder-[var(--color-text-muted)]/40 text-sm ' +
  'focus:border-[var(--color-cta)] focus:ring-4 focus:ring-[var(--color-cta)]/10 focus:outline-none ' +
  'transition-all duration-200 ' +
  'aria-[invalid=true]:border-red-400 aria-[invalid=true]:ring-4 aria-[invalid=true]:ring-red-100';

const iconClass =
  'absolute left-3.5 top-1/2 -translate-y-1/2 w-4.5 h-4.5 text-[var(--color-text-muted)]/50 ' +
  'peer-focus:text-[var(--color-cta)] transition-colors duration-200 pointer-events-none';

const labelClass =
  'block text-xs font-semibold text-[var(--color-primary)] mb-1.5 uppercase tracking-wide';
---

<div>
  <!-- Formulaire -->
  <form
    id="contact-form"
    action={formAction}
    method="POST"
    novalidate
    class="space-y-5"
  >
    <!-- Objet de l'email reçu -->
    <input type="hidden" name="_subject" value="Nouveau message depuis le site Loopa" />
    <!-- Anti-spam (honeypot) : invisible pour l'humain, piège les bots -->
    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="prenom" class={labelClass}>
          Prénom <span class="text-[var(--color-cta)]">*</span>
        </label>
        <div class="relative">
          <input
            type="text" id="prenom" name="prenom" required autocomplete="given-name"
            placeholder="Jean" aria-describedby="err-prenom"
            class={fieldClass}
          />
          <svg class={iconClass} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <p id="err-prenom" class="field-error hidden mt-1.5 text-xs text-red-600"></p>
      </div>
      <div>
        <label for="nom" class={labelClass}>
          Nom <span class="text-[var(--color-cta)]">*</span>
        </label>
        <div class="relative">
          <input
            type="text" id="nom" name="nom" required autocomplete="family-name"
            placeholder="Martin" aria-describedby="err-nom"
            class={fieldClass}
          />
          <svg class={iconClass} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <p id="err-nom" class="field-error hidden mt-1.5 text-xs text-red-600"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="email" class={labelClass}>
          Email <span class="text-[var(--color-cta)]">*</span>
        </label>
        <div class="relative">
          <input
            type="email" id="email" name="email" required autocomplete="email"
            placeholder="jean.martin@entreprise.fr" aria-describedby="err-email"
            class={fieldClass}
          />
          <svg class={iconClass} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <p id="err-email" class="field-error hidden mt-1.5 text-xs text-red-600"></p>
      </div>
      <div>
        <label for="telephone" class={labelClass}>
          Téléphone <span class="text-[var(--color-text-muted)] normal-case font-normal">(optionnel)</span>
        </label>
        <div class="relative">
          <input
            type="tel" id="telephone" name="telephone" autocomplete="tel"
            placeholder="06 12 34 56 78" aria-describedby="err-telephone"
            class={fieldClass}
          />
          <svg class={iconClass} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11 11 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <p id="err-telephone" class="field-error hidden mt-1.5 text-xs text-red-600"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div>
        <label for="entreprise" class={labelClass}>
          Entreprise <span class="text-[var(--color-text-muted)] normal-case font-normal">(optionnel)</span>
        </label>
        <div class="relative">
          <input
            type="text" id="entreprise" name="entreprise" autocomplete="organization"
            placeholder="Mon entreprise"
            class={fieldClass}
          />
          <svg class={iconClass} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3m6-14h1m-1 4h1m4-4h1m-1 4h1m-5 10v-4a1 1 0 011-1h2a1 1 0 011 1v4"/>
          </svg>
        </div>
      </div>
      <div>
        <label for="sujet" class={labelClass}>
          Votre besoin <span class="text-[var(--color-cta)]">*</span>
        </label>
        <div class="relative">
          <select id="sujet" name="sujet" required aria-describedby="err-sujet" class={`${fieldClass} appearance-none cursor-pointer pr-10`}>
            <option value="" disabled selected>Sélectionnez…</option>
            <option value="Automatisation">Automatisation / gagner du temps</option>
            <option value="Création de site web">Création de site web</option>
            <option value="Intelligence artificielle">Intelligence artificielle</option>
            <option value="Conseil & Formation">Conseil &amp; formation</option>
            <option value="Autre">Autre / je ne sais pas encore</option>
          </select>
          <svg class={iconClass} fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z"/>
          </svg>
          <!-- Chevron du select -->
          <svg class="absolute right-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-text-muted)]/60 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
        <p id="err-sujet" class="field-error hidden mt-1.5 text-xs text-red-600"></p>
      </div>
    </div>

    <div>
      <label for="message" class={labelClass}>
        Message <span class="text-[var(--color-cta)]">*</span>
      </label>
      <div class="relative">
        <textarea
          id="message" name="message" rows="5" required
          placeholder="Décrivez votre projet ou votre besoin…" aria-describedby="err-message msg-count"
          class={`${fieldClass} resize-y min-h-[140px] pt-3`}
        ></textarea>
        <svg class="absolute left-3.5 top-3.5 w-4.5 h-4.5 text-[var(--color-text-muted)]/50 peer-focus:text-[var(--color-cta)] transition-colors duration-200 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M8 10h.01M12 10h.01M16 10h.01M21 12a9 9 0 01-9 9 9 9 0 01-4.255-1.06L3 21l1.06-3.745A9 9 0 1121 12z"/>
        </svg>
      </div>
      <div class="flex justify-between items-center mt-1.5">
        <p id="err-message" class="field-error hidden text-xs text-red-600"></p>
        <span id="msg-count" class="text-xs text-[var(--color-text-muted)]/60 ml-auto">0 caractère</span>
      </div>
    </div>

    <!-- Consentement RGPD -->
    <div>
      <label class="flex items-start gap-3 cursor-pointer rounded-xl border border-[var(--color-border)] bg-white px-4 py-3.5 hover:border-[var(--color-cta)]/40 transition-colors duration-200 has-[:checked]:border-[var(--color-cta)]/50 has-[:checked]:bg-[var(--color-cta)]/[0.03]">
        <input
          type="checkbox" id="consentement" name="consentement" required value="oui"
          aria-describedby="err-consentement"
          class="mt-0.5 w-4 h-4 rounded border-[var(--color-border)] text-[var(--color-cta)]
                 focus:ring-2 focus:ring-[var(--color-cta)]/30 cursor-pointer flex-shrink-0 accent-[var(--color-cta)]"
        />
        <span class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          J'accepte que mes données soient utilisées pour traiter ma demande, conformément à la
          <a href="/confidentialite" class="text-[var(--color-cta)] font-semibold hover:underline">politique de confidentialité</a>.
          <span class="text-[var(--color-cta)]">*</span>
        </span>
      </label>
      <p id="err-consentement" class="field-error hidden mt-1.5 text-xs text-red-600"></p>
    </div>

    <!-- Error message global -->
    <div id="form-error" class="hidden rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700" role="alert">
      Une erreur est survenue. Merci de réessayer ou de nous écrire directement à {CONTACT_EMAIL}.
    </div>

    <div class="pt-1">
      <button
        id="submit-btn"
        type="submit"
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 text-sm font-semibold text-white
               bg-[var(--color-cta)] hover:bg-[var(--color-cta-hover)] rounded-xl
               shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 active:scale-[0.97]
               focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-cta)]
               disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0"
      >
        <span id="submit-label">Envoyer le message</span>
        <svg id="submit-icon" class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
        <!-- Spinner (hidden by default) -->
        <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
      </button>
      <p class="text-xs text-[var(--color-text-muted)]/70 mt-3 flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Vos données restent confidentielles. Réponse sous 24h ouvrées.
      </p>
    </div>
  </form>

  <!-- Success state (hidden) -->
  <div id="form-success" class="hidden text-center py-12 px-6">
    <div class="w-16 h-16 mx-auto rounded-full bg-green-100 flex items-center justify-center mb-5">
      <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h3 class="text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-2">
      Message envoyé !
    </h3>
    <p class="text-[var(--color-text-muted)] text-sm max-w-sm mx-auto">
      Nous vous répondons sous 24 heures ouvrées. À très vite !
    </p>
  </div>
</div>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const error   = document.getElementById('form-error');
  const submitBtn     = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel   = document.getElementById('submit-label');
  const submitIcon    = document.getElementById('submit-icon');
  const submitSpinner = document.getElementById('submit-spinner');
  const msgCount      = document.getElementById('msg-count');
  const message       = document.getElementById('message') as HTMLTextAreaElement | null;

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const PHONE_RE = /^[+0-9().\-\s]{6,}$/;

  type Field = HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;

  /* Renvoie un message d'erreur, ou '' si le champ est valide. */
  function validate(field: Field): string {
    const v = field.value.trim();
    switch (field.name) {
      case 'prenom':
      case 'nom':
        return v ? '' : 'Ce champ est requis.';
      case 'email':
        if (!v) return 'L\'email est requis.';
        return EMAIL_RE.test(v) ? '' : 'Adresse email invalide.';
      case 'telephone':
        return !v || PHONE_RE.test(v) ? '' : 'Numéro de téléphone invalide.';
      case 'sujet':
        return v ? '' : 'Merci de choisir un besoin.';
      case 'message':
        if (!v) return 'Le message est requis.';
        return v.length >= 10 ? '' : 'Message trop court (10 caractères min).';
      case 'consentement':
        return (field as HTMLInputElement).checked ? '' : 'Votre accord est nécessaire pour envoyer le message.';
      default:
        return '';
    }
  }

  function showError(field: Field, msg: string) {
    const errEl = document.getElementById(`err-${field.name}`);
    if (msg) {
      field.setAttribute('aria-invalid', 'true');
      if (errEl) { errEl.textContent = msg; errEl.classList.remove('hidden'); }
    } else {
      field.removeAttribute('aria-invalid');
      if (errEl) { errEl.textContent = ''; errEl.classList.add('hidden'); }
    }
  }

  /* Validation au blur (après une première interaction) */
  form?.querySelectorAll<Field>('input, select, textarea').forEach(field => {
    if (field.name.startsWith('_') || field.name === 'entreprise') return;
    field.addEventListener('blur', () => showError(field, validate(field)));
    field.addEventListener('input', () => {
      if (field.getAttribute('aria-invalid') === 'true') showError(field, validate(field));
    });
  });

  /* Compteur de caractères */
  message?.addEventListener('input', () => {
    if (msgCount) {
      const n = message.value.length;
      msgCount.textContent = `${n} caractère${n > 1 ? 's' : ''}`;
    }
  });

  function setLoading(loading: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = loading;
    submitLabel!.textContent = loading ? 'Envoi en cours…' : 'Envoyer le message';
    submitIcon!.classList.toggle('hidden', loading);
    submitSpinner!.classList.toggle('hidden', !loading);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    error?.classList.add('hidden');

    /* Validation complète */
    let firstInvalid: Field | null = null;
    form.querySelectorAll<Field>('input, select, textarea').forEach(field => {
      if (field.name.startsWith('_') || field.name === 'entreprise') return;
      const msg = validate(field);
      showError(field, msg);
      if (msg && !firstInvalid) firstInvalid = field;
    });
    if (firstInvalid) {
      (firstInvalid as Field).focus();
      return;
    }

    setLoading(true);
    try {
      const res = await fetch(form.action, {
        method:  'POST',
        body:    new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.classList.add('hidden');
        success?.classList.remove('hidden');
        success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        error?.classList.remove('hidden');
        setLoading(false);
      }
    } catch {
      error?.classList.remove('hidden');
      setLoading(false);
    }
  });
</script>
