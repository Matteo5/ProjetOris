---
/*
 * Section « Réalisations & exemples » de l'accueil.
 * Tant qu'il n'y a pas de portfolio client, on illustre concrètement
 * ce qu'on sait faire avec deux visuels honnêtement étiquetés « exemple » :
 *  1. un flux d'automatisation (relance de factures)
 *  2. un avant / après sur le temps gagné
 */

// Étapes du flux d'automatisation illustré.
const flow = [
  {
    label: 'Devis signé',
    sub: 'le client accepte',
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
  },
  {
    label: 'Facture générée',
    sub: 'automatiquement',
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>',
  },
  {
    label: 'Relance envoyée',
    sub: 'si pas payée',
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',
  },
  {
    label: 'Vous êtes notifié',
    sub: 'paiement reçu',
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>',
  },
];
---

<section class="py-24 bg-[var(--color-background)] relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-50" aria-hidden="true"
       style="background-image: radial-gradient(rgba(67,56,202,0.05) 1px, transparent 1px); background-size: 30px 30px;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- En-tête -->
    <div class="text-center mb-16 reveal">
      <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3">Concret</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
        Ce que ça donne, en vrai
      </h2>
      <p class="text-base text-[var(--color-text-muted)] max-w-xl mx-auto">
        Plutôt qu'une longue liste de promesses, voici concrètement le genre de choses
        qu'on met en place pour vous faire gagner du temps.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-stretch">

      <!-- ── Exemple 1 : flux d'automatisation ─────────────── -->
      <div class="reveal reveal-delay-100 flex">
        <div class="w-full bg-white rounded-2xl p-7 sm:p-8 border border-[var(--color-border)] flex flex-col" style="box-shadow: var(--shadow-sm);">
          <span class="example-pill">Exemple</span>
          <h3 class="text-lg font-bold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mt-3 mb-1">
            Relancer les factures impayées, tout seul
          </h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-7">
            Une fois posé, le système tourne sans vous. Plus aucune relance oubliée.
          </p>

          <!-- Flux -->
          <div class="flow">
            {flow.map((step, i) => (
              <>
                <div class="flow-node" style={`animation-delay: ${i * 0.4}s`}>
                  <span class="flow-icon"><Fragment set:html={step.icon} /></span>
                  <div class="min-w-0">
                    <p class="flow-label">{step.label}</p>
                    <p class="flow-sub">{step.sub}</p>
                  </div>
                </div>
                {i < flow.length - 1 && (
                  <div class="flow-arrow" aria-hidden="true">
                    <span class="flow-dot" style={`animation-delay: ${i * 0.4 + 0.2}s`}></span>
                    <svg class="w-4 h-4 rotate-90 sm:rotate-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </div>
                )}
              </>
            ))}
          </div>

          <p class="text-xs text-[var(--color-text-muted)] mt-auto pt-7 flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-[var(--color-cta)] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Adaptable à vos devis, vos plannings, vos e-mails… votre métier.
          </p>
        </div>
      </div>

      <!-- ── Exemple 2 : avant / après ─────────────────────── -->
      <div class="reveal reveal-delay-200 flex">
        <div class="w-full bg-white rounded-2xl p-7 sm:p-8 border border-[var(--color-border)] flex flex-col" style="box-shadow: var(--shadow-sm);">
          <span class="example-pill">Exemple</span>
          <h3 class="text-lg font-bold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mt-3 mb-1">
            Le temps que vous récupérez
          </h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-7">
            Quelques heures grignotées chaque semaine par des tâches manuelles… ou plus rien.
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto_1fr] gap-4 items-center flex-1">

            <!-- Avant -->
            <div class="ba-card ba-before">
              <p class="ba-tag">Avant</p>
              <p class="ba-big">2 h<span class="ba-unit">/ semaine</span></p>
              <ul class="ba-list">
                <li>Recopier les factures</li>
                <li>Penser à relancer</li>
                <li>Vérifier les paiements</li>
              </ul>
            </div>

            <!-- Flèche -->
            <div class="ba-arrow" aria-hidden="true">
              <svg class="w-6 h-6 rotate-90 sm:rotate-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>

            <!-- Après -->
            <div class="ba-card ba-after">
              <p class="ba-tag ba-tag-after">Après</p>
              <p class="ba-big ba-big-after">0 h<span class="ba-unit ba-unit-after">c'est automatique</span></p>
              <ul class="ba-list ba-list-after">
                <li><span class="ba-check">✓</span> Tout s'enchaîne seul</li>
                <li><span class="ba-check">✓</span> Vous gardez le contrôle</li>
                <li><span class="ba-check">✓</span> Vous êtes juste prévenu</li>
              </ul>
            </div>
          </div>

          <p class="text-xs text-[var(--color-text-muted)] mt-7 pt-1 flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-[var(--color-cta)] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Ce temps gagné, vous le passez sur votre vrai métier.
          </p>
        </div>
      </div>

    </div>

    <!-- Mention honnêteté -->
    <p class="text-center text-xs text-[var(--color-text-muted)]/80 mt-8 reveal">
      Exemples illustratifs. Chaque projet est unique — on l'adapte à votre activité.
    </p>
  </div>
</section>

<style>
  .example-pill {
    display: inline-block;
    align-self: flex-start;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-cta);
    background: rgba(67, 56, 202, 0.08);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
  }

  /* ── Flux d'automatisation ────────────────────────────── */
  .flow {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 640px) {
    .flow { flex-direction: row; align-items: center; }
  }

  .flow-node {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex: 1;
    min-width: 0;
    padding: 0.75rem 0.9rem;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    animation: nodePulse 3.2s var(--ease-smooth) infinite;
  }
  .flow-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    flex-shrink: 0;
    border-radius: 0.6rem;
    color: #fff;
    background: linear-gradient(145deg, var(--color-cta), #1A1A2E);
  }
  .flow-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .flow-sub {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.2;
  }

  .flow-arrow {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-border);
    flex-shrink: 0;
    padding: 0.1rem;
  }
  .flow-dot {
    position: absolute;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: var(--color-cta);
    opacity: 0;
    animation: dotFlow 3.2s var(--ease-smooth) infinite;
  }

  @keyframes nodePulse {
    0%, 100% { border-color: var(--color-border); }
    50%      { border-color: color-mix(in srgb, var(--color-cta) 35%, transparent); }
  }
  @keyframes dotFlow {
    0%, 100% { opacity: 0; transform: scale(0.6); }
    50%      { opacity: 1; transform: scale(1); }
  }

  /* ── Avant / après ────────────────────────────────────── */
  .ba-card {
    border-radius: 1rem;
    padding: 1.25rem;
    height: 100%;
  }
  .ba-before {
    background: var(--color-background);
    border: 1px solid var(--color-border);
  }
  .ba-after {
    background: linear-gradient(145deg, #4338CA 0%, #1A1A2E 100%);
    border: 1px solid transparent;
    box-shadow: var(--shadow-lg);
  }
  .ba-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }
  .ba-tag-after { color: rgba(255, 255, 255, 0.6); }
  .ba-big {
    font-family: var(--font-heading);
    font-size: 1.9rem;
    font-weight: 800;
    color: var(--color-text-muted);
    line-height: 1;
    margin-bottom: 0.9rem;
  }
  .ba-big-after { color: #fff; }
  .ba-unit {
    display: block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }
  .ba-unit-after { color: var(--color-accent); }
  .ba-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .ba-list-after { color: rgba(255, 255, 255, 0.85); }
  .ba-check {
    color: var(--color-accent);
    font-weight: 800;
    margin-right: 0.25rem;
  }
  .ba-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-cta);
  }
</style>
