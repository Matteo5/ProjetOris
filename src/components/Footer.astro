---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-primary)] text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-10">

    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-14">

      <!-- Brand col -->
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center text-2xl font-extrabold font-[family-name:var(--font-heading)] tracking-tight hover:opacity-80 transition-opacity duration-200">
          Oris<span class="text-[var(--color-accent)]">.</span>
        </a>
        <p class="mt-4 text-sm text-slate-400 leading-relaxed max-w-xs">
          Solutions d'automatisation et d'IA accessibles pour PME et indépendants en Normandie.
        </p>
        <!-- Email -->
        <a
          href="mailto:contact@oris.fr"
          class="mt-6 inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors duration-200 group"
        >
          <svg class="w-4 h-4 flex-shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          contact@oris.fr
        </a>
      </div>

      <!-- Nav -->
      <div class="md:col-span-2 md:col-start-6">
        <h4 class="text-xs font-bold uppercase tracking-[0.15em] text-slate-400 mb-5">Navigation</h4>
        <ul class="space-y-3">
          {[
            { href: '/',         label: 'Accueil' },
            { href: '/offres',   label: 'Offres' },
            { href: '/a-propos', label: 'À propos' },
            { href: '/contact',  label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-slate-400 hover:text-white transition-colors duration-200">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div class="md:col-span-3">
        <h4 class="text-xs font-bold uppercase tracking-[0.15em] text-slate-400 mb-5">Services</h4>
        <ul class="space-y-3">
          {[
            'Automatisation',
            'Intelligence artificielle',
            'Conseil & Formation',
            'Intégration d\'outils',
          ].map(s => (
            <li class="text-sm text-slate-400">{s}</li>
          ))}
        </ul>
      </div>

      <!-- Infos -->
      <div class="md:col-span-3">
        <h4 class="text-xs font-bold uppercase tracking-[0.15em] text-slate-400 mb-5">Informations</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-2 text-sm text-slate-400">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Normandie, France
          </li>
          <li class="flex items-start gap-2 text-sm text-slate-400">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Lun — Ven, 9h — 18h
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-slate-700/50 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-slate-500">&copy; {year} Oris. Tous droits réservés.</p>
      <div class="flex items-center gap-6">
        <a href="/mentions-legales"  class="text-xs text-slate-500 hover:text-slate-300 transition-colors duration-200">Mentions légales</a>
        <a href="/confidentialite"   class="text-xs text-slate-500 hover:text-slate-300 transition-colors duration-200">Confidentialité</a>
      </div>
    </div>
  </div>
</footer>
