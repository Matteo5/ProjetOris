---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import ServicesCard from '../components/ServicesCard.astro';
import MetierTabs from '../components/MetierTabs.astro';
import LogosScroll from '../components/LogosScroll.astro';
import { CALENDLY_URL } from '../config';

const services = [
  {
    title: 'Automatisation',
    description: 'Éliminez les tâches manuelles répétitives. Devis, factures, relances, planning — tout s\'enchaîne automatiquement sans intervention de votre part.',
    icon: '<svg class="w-7 h-7 text-[var(--color-cta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>',
  },
  {
    title: 'Intelligence artificielle',
    description: 'Des outils IA adaptés à votre métier : tri de documents, analyse de données, assistants conversationnels — toujours supervisés, toujours sous contrôle.',
    icon: '<svg class="w-7 h-7 text-[var(--color-cta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>',
  },
  {
    title: 'Site web vitrine',
    description: 'Un site moderne, rapide et bien visible sur Google. De la première page au déploiement, on construit votre présence en ligne, prête à convaincre.',
    icon: '<svg class="w-7 h-7 text-[var(--color-cta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
  },
  {
    title: 'Conseil & Formation',
    description: 'On vous accompagne de A à Z : audit, mise en place, formation de vos équipes. Vous restez autonomes, nous restons disponibles.',
    icon: '<svg class="w-7 h-7 text-[var(--color-cta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>',
  },
];

/* Engagements concrets pris envers chaque client (remplace les témoignages
   tant que nous n'avons pas de vrais retours à afficher). */
const engagements = [
  {
    title: 'Devis transparent',
    desc: 'Un tarif clair annoncé à l\'avance, sans coût caché ni mauvaise surprise en fin de projet.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>',
  },
  {
    title: 'Vous restez maître',
    desc: 'Vos outils, vos données, vos accès vous appartiennent. Aucune dépendance, aucune captivité technique.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>',
  },
  {
    title: 'Formation incluse',
    desc: 'On forme vos équipes et on documente tout. Vous devenez autonomes — on ne se rend jamais indispensables.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.42a12 12 0 01.84 4.42 12 12 0 01-7 1 12 12 0 01-7-1 12 12 0 01.84-4.42L12 14z"/></svg>',
  },
  {
    title: 'Sans engagement',
    desc: 'Pas de contrat qui vous enferme. On vous accompagne tant que vous y trouvez de la valeur, pas plus.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/></svg>',
  },
];

/* Engagements concrets (vrais dès le 1er jour) plutôt que des chiffres de bilan. */
const stats = [
  { value: 30,  suffix: ' min', label: 'Appel découverte offert'   },
  { value: 24,  suffix: 'h',    label: 'Réponse garantie'          },
  { value: 100, suffix: '%',    label: 'Solutions sur-mesure'      },
  { value: 0,   suffix: ' €',   label: 'Sans engagement'           },
];
---

<Layout
  title="Accueil"
  description="Snodo — Automatisation, IA et création de sites web pour PME et indépendants en Normandie. Gagnez du temps et en visibilité, concentrez-vous sur votre métier."
>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="relative py-28 sm:py-36 overflow-hidden bg-[var(--color-background)]">

    <!-- Fond animé -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <!-- Grille de points -->
      <div class="absolute inset-0 opacity-60" style="background-image: radial-gradient(rgba(67,56,202,0.10) 1px, transparent 1px); background-size: 30px 30px;"></div>
      <!-- Orbes dégradé -->
      <div class="mesh-orb absolute -top-24 right-1/4 w-[520px] h-[520px] rounded-full blur-[70px]" data-parallax="0.12"
           style="background: radial-gradient(circle at center, rgba(67,56,202,0.13), transparent 70%)"></div>
      <div class="mesh-orb-2 absolute bottom-0 left-1/5 w-[400px] h-[400px] rounded-full blur-[60px]" data-parallax="-0.09"
           style="background: radial-gradient(circle at center, rgba(6,182,212,0.09), transparent 70%)"></div>
      <div class="mesh-orb-3 absolute top-1/2 right-1/6 w-[280px] h-[280px] rounded-full blur-[50px]" data-parallax="0.2"
           style="background: radial-gradient(circle at center, rgba(245,158,11,0.07), transparent 70%)"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">

        <!-- Badge -->
        <div class="reveal inline-flex items-center gap-2 bg-[var(--color-cta)]/10 text-[var(--color-cta)] text-xs font-bold rounded-full px-4 py-2 mb-8 tracking-wide">
          <span class="ping-slow w-2 h-2 rounded-full bg-[var(--color-cta)] flex-shrink-0" aria-hidden="true"></span>
          En Normandie — et partout en France à distance
        </div>

        <!-- Titre -->
        <h1 class="reveal reveal-delay-100 text-4xl sm:text-5xl lg:text-6xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] leading-[1.1] mb-6 tracking-tight">
          Gagnez du temps,<br/>
          <span class="gradient-text">gagnez en visibilité</span>
        </h1>

        <!-- Accroche -->
        <p class="reveal reveal-delay-200 text-base sm:text-lg text-[var(--color-text-muted)] max-w-xl mx-auto mb-10 leading-relaxed">
          Automatisation, intelligence artificielle et sites web sur mesure pour les PME et indépendants.
          Simples à prendre en main, concrets dans les résultats.
        </p>

        <!-- CTAs -->
        <div class="reveal reveal-delay-300 flex flex-col sm:flex-row gap-4 justify-center">
          <Button href={CALENDLY_URL} data-calendly target="_blank" rel="noopener" variant="primary" size="lg">
            Réserver un appel découverte
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </Button>
          <Button href="/offres" variant="secondary" size="lg">
            Voir nos offres
          </Button>
        </div>
      </div>

      <!-- Stats avec counter -->
      <div class="mt-20 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto reveal reveal-delay-400">
        {stats.map((s, i) => (
          <div class="text-center">
            <div
              class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-cta)]"
              data-counter={s.value}
              data-suffix={s.suffix}
              style={`transition-delay: ${i * 120}ms`}
            >
              {s.value}{s.suffix}
            </div>
            <div class="text-xs sm:text-sm text-[var(--color-text-muted)] mt-1.5 font-medium">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── LOGOS SCROLL ───────────────────────────────────── -->
  <LogosScroll />

  <!-- ── SERVICES ──────────────────────────────────────── -->
  <section class="py-24 bg-white" id="services">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16 reveal">
        <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3">Ce que nous faisons</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-4 leading-tight">
          Des solutions concrètes,<br/>pas du jargon
        </h2>
        <p class="text-base text-[var(--color-text-muted)] max-w-xl mx-auto">
          Quatre expertises pour transformer votre quotidien professionnel sans révolution technique.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {services.map((s, i) => (
          <div class={`reveal reveal-delay-${Math.min((i + 1) * 100, 400)} flex`}>
            <ServicesCard title={s.title} description={s.description} icon={s.icon} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── MÉTIERS ────────────────────────────────────────── -->
  <MetierTabs />

  <!-- ── ENGAGEMENTS ───────────────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16 reveal">
        <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3">Nos engagements</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
          Ce sur quoi vous pouvez compter
        </h2>
        <p class="text-base text-[var(--color-text-muted)] max-w-xl mx-auto">
          Pas de promesses en l'air : voici les garanties que nous prenons avec chaque client, dès le premier échange.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {engagements.map((e, i) => (
          <div class={`reveal reveal-delay-${(i + 1) * 100} flex`}>
            <div class="group bg-[var(--color-background)] rounded-2xl p-7 border border-[var(--color-border)] tilt-card h-full flex flex-col" style="box-shadow: var(--shadow-sm);">
              <div class="tilt-icon w-12 h-12 rounded-xl bg-[var(--color-cta)]/10 flex items-center justify-center text-[var(--color-cta)] mb-5
                          transition-colors duration-300 group-hover:bg-[var(--color-cta)] group-hover:text-white">
                <Fragment set:html={e.icon} />
              </div>
              <h3 class="text-base font-bold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-2">{e.title}</h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed flex-1">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA FINAL ─────────────────────────────────────── -->
  <section class="py-28 relative overflow-hidden" style="background: linear-gradient(135deg, #1A1A2E 0%, #2D1F50 50%, #1A1A2E 100%);">
    <!-- Grille décorative -->
    <div class="absolute inset-0 pointer-events-none opacity-30" aria-hidden="true"
         style="background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 24px 24px;"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <p class="text-[var(--color-accent)] font-semibold text-xs uppercase tracking-[0.18em] mb-4">Commençons ensemble</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold font-[family-name:var(--font-heading)] text-white mb-6 leading-tight">
        Prêt à gagner du temps ?
      </h2>
      <p class="text-base text-slate-300 max-w-xl mx-auto mb-10 leading-relaxed">
        Un appel de 30 minutes suffit pour identifier vos premières pistes d'automatisation.
        Sans engagement, sans jargon.
      </p>
      <Button href={CALENDLY_URL} data-calendly target="_blank" rel="noopener" variant="primary" size="lg">
        Réserver mon appel gratuit
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </Button>
    </div>
  </section>

</Layout>
