---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import ServicesCard from '../components/ServicesCard.astro';
import MetierTabs from '../components/MetierTabs.astro';
import LogosScroll from '../components/LogosScroll.astro';

const services = [
  {
    title: 'Automatisation',
    description: 'Éliminez les tâches manuelles répétitives. Devis, factures, relances, planning — tout s\'enchaîne automatiquement sans intervention de votre part.',
    icon: '<svg class="w-7 h-7 text-[var(--color-cta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>',
  },
  {
    title: 'Intelligence artificielle',
    description: 'Des outils IA adaptés à votre métier : tri de documents, analyse de données, assistants conversationnels — toujours supervisés, toujours sous contrôle.',
    icon: '<svg class="w-7 h-7 text-[var(--color-cta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>',
  },
  {
    title: 'Conseil & Formation',
    description: 'On vous accompagne de A à Z : audit, mise en place, formation de vos équipes. Vous restez autonomes, nous restons disponibles.',
    icon: '<svg class="w-7 h-7 text-[var(--color-cta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>',
  },
];

const testimonials = [
  {
    quote: 'On perdait 2 heures par jour sur les relances. Maintenant tout part automatiquement. On se concentre enfin sur les chantiers.',
    name: 'Pierre D.',
    role: 'Artisan plombier, Rouen',
    initials: 'PD',
  },
  {
    quote: 'L\'IA trie mes documents comptables en quelques secondes. J\'ai retrouvé un vrai confort de travail, c\'est bluffant.',
    name: 'Sophie L.',
    role: 'Expert-comptable, Caen',
    initials: 'SL',
  },
  {
    quote: 'En 3 semaines, notre CRM était en place et nos équipes formées. Le ROI est visible dès le premier mois.',
    name: 'Marc B.',
    role: 'Dirigeant PME, Le Havre',
    initials: 'MB',
  },
];

const stats = [
  { value: 50,  suffix: '+', label: 'Projets livrés'      },
  { value: 98,  suffix: '%', label: 'Satisfaction client'  },
  { value: 10,  suffix: 'h', label: 'Gagnées par semaine'  },
  { value: 24,  suffix: 'h', label: 'Temps de réponse max' },
];
---

<Layout
  title="Accueil"
  description="Oris — Solutions d'automatisation et d'IA simples pour PME et indépendants en Normandie. Gagnez du temps, concentrez-vous sur votre métier."
>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="relative py-28 sm:py-36 overflow-hidden bg-[var(--color-background)]">

    <!-- Fond animé -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <!-- Grille de points -->
      <div class="absolute inset-0 opacity-60" style="background-image: radial-gradient(rgba(67,56,202,0.10) 1px, transparent 1px); background-size: 30px 30px;"></div>
      <!-- Orbes dégradé -->
      <div class="mesh-orb absolute -top-24 right-1/4 w-[520px] h-[520px] rounded-full blur-[70px]"
           style="background: radial-gradient(circle at center, rgba(67,56,202,0.13), transparent 70%)"></div>
      <div class="mesh-orb-2 absolute bottom-0 left-1/5 w-[400px] h-[400px] rounded-full blur-[60px]"
           style="background: radial-gradient(circle at center, rgba(6,182,212,0.09), transparent 70%)"></div>
      <div class="mesh-orb-3 absolute top-1/2 right-1/6 w-[280px] h-[280px] rounded-full blur-[50px]"
           style="background: radial-gradient(circle at center, rgba(245,158,11,0.07), transparent 70%)"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">

        <!-- Badge -->
        <div class="reveal inline-flex items-center gap-2 bg-[var(--color-cta)]/10 text-[var(--color-cta)] text-xs font-bold rounded-full px-4 py-2 mb-8 tracking-wide">
          <span class="ping-slow w-2 h-2 rounded-full bg-[var(--color-cta)] flex-shrink-0" aria-hidden="true"></span>
          Basé en Normandie — Disponible partout
        </div>

        <!-- Titre -->
        <h1 class="reveal reveal-delay-100 text-4xl sm:text-5xl lg:text-6xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] leading-[1.1] mb-6 tracking-tight">
          Automatisez le répétitif,<br/>
          <span class="gradient-text">concentrez-vous sur l'essentiel</span>
        </h1>

        <!-- Accroche -->
        <p class="reveal reveal-delay-200 text-base sm:text-lg text-[var(--color-text-muted)] max-w-xl mx-auto mb-10 leading-relaxed">
          Solutions d'automatisation et d'IA conçues pour les PME et indépendants.
          Simples à prendre en main, concrètes dans les résultats.
        </p>

        <!-- CTAs -->
        <div class="reveal reveal-delay-300 flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/contact" variant="primary" size="lg">
            Réserver un appel découverte
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </Button>
          <Button href="/offres" variant="secondary" size="lg">
            Voir nos offres
          </Button>
        </div>
      </div>

      <!-- Stats avec counter -->
      <div class="mt-20 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto reveal reveal-delay-400">
        {stats.map((s, i) => (
          <div class="text-center">
            <div
              class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-cta)]"
              data-counter={s.value}
              data-suffix={s.suffix}
              style={`transition-delay: ${i * 120}ms`}
            >
              {s.value}{s.suffix}
            </div>
            <div class="text-xs sm:text-sm text-[var(--color-text-muted)] mt-1.5 font-medium">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── LOGOS SCROLL ───────────────────────────────────── -->
  <LogosScroll />

  <!-- ── SERVICES ──────────────────────────────────────── -->
  <section class="py-24 bg-white" id="services">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16 reveal">
        <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3">Ce que nous faisons</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-4 leading-tight">
          Des solutions concrètes,<br/>pas du jargon
        </h2>
        <p class="text-base text-[var(--color-text-muted)] max-w-xl mx-auto">
          Trois piliers pour transformer votre quotidien professionnel sans révolution technique.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        {services.map((s, i) => (
          <div class={`reveal reveal-delay-${(i + 1) * 100} flex`}>
            <ServicesCard title={s.title} description={s.description} icon={s.icon} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── MÉTIERS ────────────────────────────────────────── -->
  <MetierTabs />

  <!-- ── TÉMOIGNAGES ───────────────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16 reveal">
        <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3">Témoignages</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] leading-tight">
          Ce qu'en disent nos clients
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class={`reveal reveal-delay-${(i + 1) * 100}`}>
            <div class="bg-[var(--color-background)] rounded-2xl p-8 border border-[var(--color-border)] card-lift relative overflow-hidden h-full flex flex-col" style="box-shadow: var(--shadow-sm);">
              <!-- Guillemet décoratif -->
              <span class="absolute top-3 right-5 text-7xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-cta)]/8 leading-none select-none" aria-hidden="true">"</span>

              <!-- Étoiles -->
              <div class="flex gap-1 mb-5" aria-label="5 étoiles sur 5">
                {Array(5).fill(0).map(() => (
                  <svg class="w-4 h-4 text-[var(--color-gold)]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>

              <!-- Citation -->
              <blockquote class="text-[var(--color-secondary)] leading-relaxed text-sm mb-6 flex-1 italic">
                "{t.quote}"
              </blockquote>

              <!-- Auteur -->
              <div class="flex items-center gap-3 mt-auto">
                <div class="w-10 h-10 rounded-full bg-[var(--color-cta)]/12 flex items-center justify-center flex-shrink-0">
                  <span class="text-[var(--color-cta)] font-bold text-xs font-[family-name:var(--font-heading)]">{t.initials}</span>
                </div>
                <div>
                  <p class="font-bold text-[var(--color-primary)] text-sm">{t.name}</p>
                  <p class="text-[var(--color-text-muted)] text-xs">{t.role}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA FINAL ─────────────────────────────────────── -->
  <section class="py-28 relative overflow-hidden" style="background: linear-gradient(135deg, #1A1A2E 0%, #2D1F50 50%, #1A1A2E 100%);">
    <!-- Grille décorative -->
    <div class="absolute inset-0 pointer-events-none opacity-30" aria-hidden="true"
         style="background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 24px 24px;"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <p class="text-[var(--color-accent)] font-semibold text-xs uppercase tracking-[0.18em] mb-4">Commençons ensemble</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold font-[family-name:var(--font-heading)] text-white mb-6 leading-tight">
        Prêt à gagner du temps ?
      </h2>
      <p class="text-base text-slate-300 max-w-xl mx-auto mb-10 leading-relaxed">
        Un appel de 30 minutes suffit pour identifier vos premières pistes d'automatisation.
        Sans engagement, sans jargon.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Réserver mon appel gratuit
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </Button>
    </div>
  </section>

</Layout>
