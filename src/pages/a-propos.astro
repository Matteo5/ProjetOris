---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const values = [
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    title: 'Confiance',
    desc: 'Transparence totale sur nos méthodes, nos tarifs et nos résultats. Aucun engagement caché.',
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    title: 'Simplicité',
    desc: 'Pas de jargon. Des outils intuitifs qui s\'adoptent en quelques heures, pas en quelques mois.',
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    title: 'Proximité',
    desc: 'Basés en Normandie, nous intervenons sur place et à distance. Vos équipes, nos partenaires.',
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
    title: 'Résultats',
    desc: 'On mesure l\'impact concret : temps gagné, erreurs évitées, satisfaction. Le ROI prime sur tout.',
  },
];
---

<Layout
  title="À propos"
  description="Découvrez Snodo : notre mission, nos valeurs et l'équipe derrière les solutions d'automatisation pour PME en Normandie."
>

  <!-- ── HERO ───────────────────────────────── -->
  <section class="py-20 sm:py-28 bg-[var(--color-background)] relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
         style="background-image: radial-gradient(rgba(67,56,202,0.07) 1px, transparent 1px); background-size: 28px 28px;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3 reveal">À propos</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-6 leading-tight tracking-tight reveal reveal-delay-100">
          La technologie au service<br/>de ceux qui font
        </h1>
        <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-2xl reveal reveal-delay-200">
          Snodo est né d'un constat simple : les outils d'automatisation et d'IA existent, mais ils sont souvent
          pensés pour les grandes entreprises. Notre mission, c'est de les rendre accessibles aux artisans,
          commerçants, professions libérales et PME.
        </p>
      </div>
    </div>
  </section>

  <!-- ── MISSION ────────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Texte mission -->
        <div class="reveal-left">
          <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-4">Notre mission</p>
          <h2 class="text-3xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-6 leading-tight">
            Simplifier, pas compliquer
          </h2>
          <div class="space-y-5 text-[var(--color-text-muted)] leading-relaxed text-sm">
            <p>
              Chaque jour, des milliers de professionnels passent des heures sur des tâches répétitives
              qui pourraient être automatisées : saisie de données, relances, gestion de planning, tri de documents…
            </p>
            <p>
              Chez Snodo, nous croyons que la technologie doit simplifier le quotidien, pas le compliquer.
              C'est pourquoi nous concevons des solutions qui se fondent dans vos habitudes de travail existantes.
            </p>
          </div>

          <!-- Pull quote -->
          <div class="mt-8 pl-5 border-l-2 border-[var(--color-cta)]">
            <p class="text-[var(--color-secondary)] font-semibold leading-relaxed text-base italic">
              "Vous gagnez du temps, réduisez les erreurs, et vous concentrez sur ce qui compte vraiment — votre métier et vos clients."
            </p>
          </div>
        </div>

        <!-- Valeurs -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {values.map((v, i) => (
            <div class={`reveal reveal-delay-${(i + 1) * 100}`}>
              <div class="bg-[var(--color-background)] rounded-2xl p-6 border border-[var(--color-border)] card-lift h-full" style="box-shadow: var(--shadow-sm);">
                <div class="w-11 h-11 rounded-xl bg-[var(--color-cta)]/10 flex items-center justify-center mb-4 text-[var(--color-cta)]">
                  <Fragment set:html={v.icon} />
                </div>
                <h3 class="font-bold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-2 text-base">{v.title}</h3>
                <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{v.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CHIFFRES ───────────────────────────── -->
  <section class="py-20 bg-[var(--color-background)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 max-w-3xl mx-auto text-center">
        {[
          { value: 3,   suffix: '',  label: 'Domaines d\'expertise' },
          { value: 4,   suffix: '',  label: 'Secteurs accompagnés'  },
          { value: 24,  suffix: 'h', label: 'Réponse garantie'      },
          { value: 100, suffix: '%', label: 'Sur-mesure'            },
        ].map((s, i) => (
          <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
            <div
              class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-cta)] mb-1"
              data-counter={s.value}
              data-suffix={s.suffix}
            >
              {s.value}{s.suffix}
            </div>
            <p class="text-xs text-[var(--color-text-muted)] font-medium">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────── -->
  <section class="py-24 relative overflow-hidden" style="background: linear-gradient(135deg, #1A1A2E 0%, #2D1F50 50%, #1A1A2E 100%);">
    <div class="absolute inset-0 pointer-events-none opacity-25"
         style="background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 22px 22px;"
         aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-white mb-5 leading-tight">
        Envie d'en savoir plus ?
      </h2>
      <p class="text-base text-slate-300 max-w-xl mx-auto mb-8 leading-relaxed">
        Discutons de votre activité et découvrons ensemble comment l'automatisation peut vous aider.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Prendre rendez-vous
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </Button>
    </div>
  </section>

</Layout>
