---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const plans = [
  {
    id: 'audit',
    label: 'Audit & Diagnostic',
    sublabel: 'Comprendre vos besoins réels',
    price: '490€',
    period: 'HT',
    featured: false,
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>',
    items: [
      'Analyse de vos processus actuels',
      'Identification des gains rapides',
      'Rapport avec plan d\'action priorisé',
      '1h de restitution en visio',
    ],
    cta: 'Démarrer l\'audit',
    ctaVariant: 'secondary' as const,
  },
  {
    id: 'auto',
    label: 'Automatisation',
    sublabel: 'Mise en place clé en main',
    price: 'Sur devis',
    period: '',
    featured: true,
    badge: 'Le plus populaire',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    items: [
      'Tout l\'audit inclus',
      'Développement et déploiement',
      'Formation de vos équipes',
      '1 mois de support inclus',
      'Documentation complète',
    ],
    cta: 'Demander un devis',
    ctaVariant: 'primary' as const,
  },
  {
    id: 'support',
    label: 'Accompagnement',
    sublabel: 'Support continu',
    price: '390€',
    period: '/ mois HT',
    featured: false,
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>',
    items: [
      'Maintenance et mises à jour',
      'Support prioritaire par email',
      '1 appel de suivi mensuel',
      'Évolutions mineures incluses',
    ],
    cta: 'Nous contacter',
    ctaVariant: 'secondary' as const,
  },
];

const steps = [
  {
    num: '01',
    title: 'On vous écoute',
    desc: 'On prend le temps de comprendre votre quotidien, vos irritants et vos priorités. Aucune technique, juste votre réalité de terrain.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>',
  },
  {
    num: '02',
    title: 'On diagnostique',
    desc: 'On identifie les automatisations à fort impact : celles qui vous feront gagner du temps dès la première semaine.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
  },
  {
    num: '03',
    title: 'On met en place',
    desc: 'On développe, on teste, on déploie. Vous validez chaque étape — pas de mauvaise surprise à l\'arrivée.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
  },
  {
    num: '04',
    title: 'Vous êtes autonomes',
    desc: 'Formation, documentation, support : vos équipes maîtrisent les outils. On reste disponibles, jamais indispensables.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/></svg>',
  },
  {
    num: '05',
    title: 'On reste à vos côtés',
    desc: 'Un besoin, une évolution, une question ? On est là quand il faut, à votre rythme. Support et améliorations selon vos besoins, sans engagement.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636a9 9 0 010 12.728m-3.536-3.536a4 4 0 010-5.656M12 12h.01M8.464 8.464a4 4 0 000 5.656m-3.535-9.192a9 9 0 000 12.728"/></svg>',
  },
];
---

<Layout
  title="Nos offres"
  description="Découvrez les offres Snodo : audit, automatisation et IA sur mesure pour PME et indépendants. Tarifs clairs, sans engagement."
>

  <!-- ── HERO ───────────────────────────────── -->
  <section class="py-20 sm:py-28 bg-[var(--color-background)] relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
         style="background-image: radial-gradient(rgba(67,56,202,0.07) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3 reveal">Nos offres</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-5 leading-tight tracking-tight reveal reveal-delay-100">
        Des formules claires,<br/>adaptées à chaque besoin
      </h1>
      <p class="text-base text-[var(--color-text-muted)] max-w-xl mx-auto reveal reveal-delay-200">
        Pas de surprise, pas de petit astérisque. Choisissez la formule qui vous correspond
        ou contactez-nous pour du sur-mesure.
      </p>
    </div>
  </section>

  <!-- ── PRICING CARDS ──────────────────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        {plans.map((plan, i) => (
          <div class={`reveal reveal-delay-${(i + 1) * 100} flex`}>
            {plan.featured ? (
              /* Featured card — gradient indigo */
              <div class="relative flex flex-col w-full rounded-2xl p-8 overflow-hidden"
                   style="background: linear-gradient(145deg, #4338CA 0%, #1A1A2E 100%); box-shadow: var(--shadow-xl);">
                <!-- Badge -->
                <div class="absolute top-5 right-5">
                  <span class="text-xs font-bold bg-[var(--color-gold)] text-[var(--color-primary)] px-3 py-1 rounded-full uppercase tracking-wide">
                    {plan.badge}
                  </span>
                </div>

                <!-- Icon -->
                <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center mb-5 text-white">
                  <Fragment set:html={plan.icon} />
                </div>

                <h3 class="text-xl font-bold font-[family-name:var(--font-heading)] text-white mb-1">{plan.label}</h3>
                <p class="text-white/60 text-sm mb-5">{plan.sublabel}</p>

                <div class="mb-6">
                  <span class="text-4xl font-extrabold font-[family-name:var(--font-heading)] text-white">{plan.price}</span>
                </div>

                <ul class="space-y-3 mb-8 flex-1">
                  {plan.items.map(item => (
                    <li class="flex items-start gap-3 text-white/80 text-sm">
                      <span class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>

                <a
                  href="/contact"
                  class="block text-center w-full px-6 py-3 bg-white text-[var(--color-cta)] font-bold rounded-xl
                         hover:bg-slate-100 transition-colors duration-200 active:scale-[0.97] text-sm"
                >
                  {plan.cta}
                </a>
              </div>
            ) : (
              /* Standard card */
              <div class="flex flex-col w-full bg-white rounded-2xl p-8 border border-[var(--color-border)] card-lift" style="box-shadow: var(--shadow-sm);">
                <div class="w-12 h-12 rounded-xl bg-[var(--color-cta)]/10 flex items-center justify-center mb-5 text-[var(--color-cta)]">
                  <Fragment set:html={plan.icon} />
                </div>
                <h3 class="text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-1">{plan.label}</h3>
                <p class="text-[var(--color-text-muted)] text-sm mb-5">{plan.sublabel}</p>
                <div class="mb-6">
                  <span class="text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)]">{plan.price}</span>
                  {plan.period && <span class="text-[var(--color-text-muted)] ml-1 text-sm">{plan.period}</span>}
                </div>
                <ul class="space-y-3 mb-8 flex-1">
                  {plan.items.map(item => (
                    <li class="flex items-start gap-3 text-[var(--color-secondary)] text-sm">
                      <span class="w-5 h-5 rounded-full bg-[var(--color-cta)]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-3 h-3 text-[var(--color-cta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                        </svg>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>
                <Button href="/contact" variant={plan.ctaVariant} class="w-full mt-auto">{plan.cta}</Button>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PROCESSUS ──────────────────────────── -->
  <section class="py-24 bg-[var(--color-background)] relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50" aria-hidden="true"
         style="background-image: radial-gradient(rgba(67,56,202,0.05) 1px, transparent 1px); background-size: 30px 30px;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3">Comment ça se passe</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
          De votre premier appel<br/>à votre autonomie complète
        </h2>
        <p class="text-base text-[var(--color-text-muted)] max-w-xl mx-auto">
          Une méthode en 5 étapes, simple et transparente. Vous savez toujours où vous en êtes.
        </p>
      </div>

      <div class="relative">
        <!-- Ligne de progression animée (desktop) -->
        <div class="hidden lg:block absolute top-9 left-[10%] right-[10%] h-0.5 bg-[var(--color-border)] rounded-full overflow-hidden" aria-hidden="true">
          <div id="process-line" class="h-full w-0 bg-gradient-to-r from-[var(--color-cta)] to-[var(--color-accent)] rounded-full transition-[width] duration-[1400ms] ease-out"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-8 gap-y-12">
          {steps.map((s, i) => (
            <div class={`group text-center reveal reveal-delay-${(i + 1) * 100}`}>
              <!-- Pastille numéro + icône -->
              <div class="relative w-[72px] h-[72px] mx-auto mb-6">
                <div class="absolute inset-0 rounded-2xl bg-white border border-[var(--color-border)] flex items-center justify-center
                            transition-all duration-300 z-10
                            group-hover:bg-[var(--color-cta)] group-hover:border-[var(--color-cta)] group-hover:-translate-y-1"
                     style="box-shadow: var(--shadow-sm);">
                  <span class="text-[var(--color-cta)] transition-colors duration-300 group-hover:text-white">
                    <Fragment set:html={s.icon} />
                  </span>
                </div>
                <!-- Badge numéro -->
                <span class="absolute -top-2 -right-1 z-20 w-7 h-7 rounded-full bg-[var(--color-primary)] text-white
                             text-xs font-bold font-[family-name:var(--font-heading)] flex items-center justify-center
                             border-2 border-[var(--color-background)] transition-transform duration-300 group-hover:scale-110">
                  {s.num}
                </span>
              </div>
              <h3 class="text-base font-bold font-[family-name:var(--font-heading)] text-[var(--color-primary)] mb-2">{s.title}</h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    /* Remplit la ligne de progression quand la section entre dans le viewport */
    const line = document.getElementById('process-line');
    if (line) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            line.style.width = '100%';
            obs.disconnect();
          }
        });
      }, { threshold: 0.4 });
      obs.observe(line);
    }
  </script>

  <!-- ── CTA ───────────────────────────────── -->
  <section class="py-20 relative overflow-hidden" style="background: linear-gradient(135deg, #1A1A2E 0%, #2D1F50 50%, #1A1A2E 100%);">
    <div class="absolute inset-0 pointer-events-none opacity-25"
         style="background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 22px 22px;"
         aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl sm:text-4xl font-extrabold font-[family-name:var(--font-heading)] text-white mb-5 leading-tight">
        Un projet ? Parlons-en.
      </h2>
      <p class="text-base text-slate-300 mb-8 leading-relaxed">
        Chaque mission démarre par un appel gratuit de 30 minutes. Pas de pression, que des réponses.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Réserver un appel gratuit
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </Button>
    </div>
  </section>

</Layout>
