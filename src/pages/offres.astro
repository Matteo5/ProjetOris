---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import OfferModal from '../components/OfferModal.astro';
import { SITE_URL } from '../config';

/* ── AUTOMATISATION & IA ────────────────────────────────── */
const autoPlans = [
  {
    id: 'diagnostic',
    label: 'Diagnostic',
    forWho: 'Vous hésitez encore',
    sublabel: 'On regarde ensemble ce qui vous ferait gagner du temps.',
    price: '150€',
    priceSub: 'une fois',
    priceMonthly: null,
    featured: false,
    badge: null,
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>',
    items: [
      'Un appel d\'1h pour faire le point',
      'Vos 3 priorités identifiées',
      'Un plan d\'action clair, écrit',
    ],
    cta: 'Réserver un diagnostic',
    ctaVariant: 'secondary' as const,
  },
  {
    id: 'starter',
    label: 'Starter',
    forWho: 'Quelques tâches répétitives à supprimer',
    sublabel: 'L\'essentiel automatisé, sans prise de tête.',
    price: '400€',
    priceSub: 'pour démarrer',
    priceMonthly: 'puis 49€ / mois',
    featured: false,
    badge: null,
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    items: [
      'Jusqu\'à 3 automatisations sur mesure',
      'Votre espace privé, prêt à l\'emploi',
      'Une formation pour tout comprendre',
      'Un support qui répond sous 24h',
    ],
    cta: 'Choisir Starter',
    ctaVariant: 'secondary' as const,
  },
  {
    id: 'business',
    label: 'Business',
    forWho: 'Plusieurs process à connecter entre eux',
    sublabel: 'Vos outils travaillent enfin ensemble.',
    price: '800€',
    priceSub: 'pour démarrer',
    priceMonthly: 'puis 89€ / mois',
    featured: true,
    badge: 'Le plus choisi',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>',
    items: [
      'Jusqu\'à 8 automatisations avancées',
      'Vos outils existants reliés ensemble',
      'Une formation pour vous et votre équipe',
      'Support prioritaire sous 4h',
      '1h d\'ajustements offerte chaque mois',
    ],
    cta: 'Choisir Business',
    ctaVariant: 'primary' as const,
  },
];

/* ── SITE VITRINE ───────────────────────────────────────── */
const webPlans = [
  {
    id: 'landing',
    label: 'Page Unique',
    forWho: 'Vous voulez exister en ligne, vite',
    sublabel: 'Une belle page qui présente tout l\'essentiel.',
    price: '400€',
    priceSub: 'tout compris',
    priceMonthly: null,
    featured: false,
    badge: null,
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',
    items: [
      'Une page complète et soignée',
      'Parfaite sur mobile comme sur ordinateur',
      'Un bouton de contact qui marche',
      'Visible sur Google dès le départ',
    ],
    cta: 'Demander un devis',
    ctaVariant: 'secondary' as const,
  },
  {
    id: 'vitrine',
    label: 'Site Vitrine',
    forWho: 'Vous voulez un vrai site, complet',
    sublabel: 'Plusieurs pages pour raconter votre activité.',
    price: '800€',
    priceSub: 'tout compris',
    priceMonthly: null,
    featured: true,
    badge: 'Le plus demandé',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zm12 0a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>',
    items: [
      '4 à 5 pages à votre image',
      'Un design unique, pensé pour vous',
      'Bien référencé sur Google',
      'Hébergement rapide inclus 1 an',
      'Vous modifiez vos textes facilement',
    ],
    cta: 'Choisir le Site Vitrine',
    ctaVariant: 'primary' as const,
  },
  {
    id: 'vitrine-plus',
    label: 'Site Complet',
    forWho: 'Vous voulez aussi publier et suivre',
    sublabel: 'Un site qui vit, avec blog et statistiques.',
    price: '1 400€',
    priceSub: 'tout compris',
    priceMonthly: null,
    featured: false,
    badge: null,
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>',
    items: [
      'Tout le Site Vitrine, et plus',
      'Un espace blog pour publier',
      'Les statistiques de visite',
      'Mentions légales et RGPD en règle',
    ],
    cta: 'Demander un devis',
    ctaVariant: 'secondary' as const,
  },
];

/* ── MÉTHODE ──────────────────────────────────────────── */
const steps = [
  {
    num: '01',
    title: 'On vous écoute',
    desc: 'On comprend votre quotidien et vos priorités. Aucune technique, juste votre réalité de terrain.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>',
  },
  {
    num: '02',
    title: 'On diagnostique',
    desc: 'On repère ce qui aura le plus d\'impact : ce qui vous fera gagner du temps dès la première semaine.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
  },
  {
    num: '03',
    title: 'On met en place',
    desc: 'On construit, on teste, on lance. Vous validez chaque étape — aucune mauvaise surprise.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
  },
  {
    num: '04',
    title: 'Vous êtes autonomes',
    desc: 'Formation et support : vous maîtrisez vos outils. On reste disponibles, jamais indispensables.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/></svg>',
  },
  {
    num: '05',
    title: 'On reste à vos côtés',
    desc: 'Un besoin, une question ? On est là quand il faut, à votre rythme, sans engagement.',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636a9 9 0 010 12.728m-3.536-3.536a4 4 0 010-5.656M12 12h.01M8.464 8.464a4 4 0 000 5.656m-3.535-9.192a9 9 0 000 12.728"/></svg>',
  },
];

/* ── FAQ « prix » (lève les objections au moment du choix) ── */
const faqs = [
  {
    q: 'Pourquoi un abonnement mensuel plutôt qu\'un paiement unique ?',
    a: 'Le mensuel couvre votre espace privé hébergé, les mises à jour, la surveillance et notre disponibilité quand vous avez une question. Vous ne payez pas un outil figé, mais un service vivant qui reste à jour et fonctionnel dans le temps.',
  },
  {
    q: 'Je peux arrêter quand je veux ?',
    a: 'Oui, sans engagement. Vous pouvez stopper l\'abonnement à tout moment. On vous prévient simplement à l\'avance de ce qui se passe pour vos automatisations afin que rien ne s\'arrête du jour au lendemain.',
  },
  {
    q: 'Mes outils et mes données m\'appartiennent-ils ?',
    a: 'Totalement. Votre espace, vos accès et vos données sont à vous. Le jour où vous souhaitez devenir autonome ou partir, on vous transfère l\'ensemble — aucune dépendance, aucune captivité technique.',
  },
  {
    q: 'Le prix annoncé, c\'est vraiment tout compris ?',
    a: 'Oui. Le prix de mise en place est annoncé à l\'avance, et l\'hébergement est inclus dans le mensuel. Pas de coût caché. Seules les évolutions hors du périmètre prévu font l\'objet d\'un devis clair, validé par vous avant tout travail.',
  },
  {
    q: 'Je ne sais pas quelle formule choisir, comment faire ?',
    a: 'C\'est normal, et c\'est justement notre rôle. Commencez par l\'appel découverte gratuit de 30 minutes (ou le Diagnostic à 150€) : on regarde votre situation et on vous oriente honnêtement vers ce qui vous convient — même si c\'est la formule la plus simple.',
  },
];

/* ── Schema.org Service (SEO — aide Google à comprendre l'offre) ── */
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: "Automatisation, intelligence artificielle et création de site web",
  provider: { '@type': 'LocalBusiness', name: 'Loopa', url: SITE_URL },
  areaServed: { '@type': 'State', name: 'Normandie' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Offres Loopa',
    itemListElement: [...autoPlans, ...webPlans].map((p) => ({
      '@type': 'Offer',
      name: p.label,
      description: p.sublabel,
      price: p.price.replace(/[^0-9]/g, ''),
      priceCurrency: 'EUR',
    })),
  },
};
---

<Layout
  title="Nos offres"
  description="Automatisation, IA et création de site vitrine pour artisans, TPE et indépendants. Des formules claires, des prix transparents, sans engagement."
>
  <!-- Schema Service spécifique à la page Offres -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- ── HERO ───────────────────────────────────────────── -->
  <section class="relative pt-20 sm:pt-28 pb-16 overflow-hidden bg-[var(--color-background)]">
    <div class="absolute -top-24 -left-24 w-80 h-80 rounded-full mesh-orb pointer-events-none" data-parallax="0.14"
         style="background: radial-gradient(circle, rgba(67,56,202,0.18), transparent 70%);" aria-hidden="true"></div>
    <div class="absolute top-10 -right-20 w-72 h-72 rounded-full mesh-orb-2 pointer-events-none" data-parallax="-0.1"
         style="background: radial-gradient(circle, rgba(6,182,212,0.16), transparent 70%);" aria-hidden="true"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-4 reveal">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-cta)] ping-slow"></span>
        Nos offres
      </span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-[var(--color-primary)] mb-5 leading-[1.1] tracking-tight reveal reveal-delay-100">
        Qu'est-ce qui vous<br/><span class="gradient-text">ferait gagner du temps ?</span>
      </h1>
      <p class="text-base sm:text-lg text-[var(--color-text-muted)] max-w-xl mx-auto reveal reveal-delay-200">
        Deux façons de vous simplifier la vie. Choisissez la vôtre — les formules apparaissent juste en dessous.
      </p>
    </div>
  </section>

  <!-- ── SÉLECTEUR DE CHEMIN ────────────────────────────── -->
  <section class="bg-[var(--color-background)] pb-4">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

        <!-- Chemin Automatisation -->
        <button type="button" class="path-card group reveal reveal-delay-100"
                data-target="panel-auto" aria-expanded="false" aria-controls="panel-auto">
          <div class="path-icon">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold text-[var(--color-primary)] mb-2">Je veux gagner du temps</h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-4 leading-relaxed">
            Vous faites trop de tâches répétitives à la main ? On les automatise pour vous.
          </p>
          <span class="path-link">
            <span class="path-link-show">Voir les formules</span>
            <span class="path-link-hide">Masquer</span>
            <svg class="path-chevron w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </span>
        </button>

        <!-- Chemin Site web -->
        <button type="button" class="path-card group reveal reveal-delay-200"
                data-target="panel-web" aria-expanded="false" aria-controls="panel-web">
          <div class="path-icon">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold text-[var(--color-primary)] mb-2">Je veux un site web</h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-4 leading-relaxed">
            Pas de site, ou un site qui fait fuir ? On vous construit une vraie vitrine.
          </p>
          <span class="path-link">
            <span class="path-link-show">Voir les formules</span>
            <span class="path-link-hide">Masquer</span>
            <svg class="path-chevron w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </span>
        </button>

      </div>

      <!-- Invite quand rien n'est sélectionné -->
      <p id="select-hint" class="text-center text-sm text-[var(--color-text-muted)] mt-8 reveal">
        ☝️ Cliquez sur l'une des deux cartes pour découvrir les formules et les prix.
      </p>
    </div>
  </section>

  <!-- ── PANNEAU : AUTOMATISATION ───────────────────────── -->
  <div id="panel-auto" class="formula-panel bg-white scroll-mt-6" hidden>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center max-w-2xl mx-auto mb-12 panel-head">
        <h2 class="text-3xl font-extrabold text-[var(--color-primary)] mb-3">Gagner du temps</h2>
        <p class="text-base text-[var(--color-text-muted)]">
          On supprime les tâches répétitives qui vous mangent vos journées.
          Un espace privé et sécurisé, rien que pour vous.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        {autoPlans.map((plan) => (
          <div class="formula-col flex">
            <article class={`pricing-card tilt-card group ${plan.featured ? 'pricing-card--featured' : ''}`}>
              {plan.badge && <span class="pricing-badge">{plan.badge}</span>}
              <div class={`pricing-icon ${plan.featured ? 'pricing-icon--featured' : ''}`}>
                <Fragment set:html={plan.icon} />
              </div>
              <span class={`for-who ${plan.featured ? 'for-who--featured' : ''}`}>{plan.forWho}</span>
              <h3 class={`text-xl font-bold mb-1 ${plan.featured ? 'text-white' : 'text-[var(--color-primary)]'}`}>{plan.label}</h3>
              <p class={`text-sm mb-5 leading-relaxed ${plan.featured ? 'text-white/60' : 'text-[var(--color-text-muted)]'}`}>{plan.sublabel}</p>
              <div class="mb-6">
                <div class="flex items-baseline gap-1.5">
                  <span class={`text-4xl font-extrabold ${plan.featured ? 'text-white' : 'text-[var(--color-primary)]'}`}>{plan.price}</span>
                  <span class={`text-sm ${plan.featured ? 'text-white/50' : 'text-[var(--color-text-muted)]'}`}>{plan.priceSub}</span>
                </div>
                {plan.priceMonthly && (
                  <p class={`text-sm font-semibold mt-1 ${plan.featured ? 'text-white/80' : 'text-[var(--color-cta)]'}`}>{plan.priceMonthly}</p>
                )}
              </div>
              <ul class="space-y-3 mb-8 flex-1">
                {plan.items.map(item => (
                  <li class={`flex items-start gap-3 text-sm ${plan.featured ? 'text-white/85' : 'text-[var(--color-secondary)]'}`}>
                    <span class={`check ${plan.featured ? 'check--featured' : ''}`}>
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                      </svg>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
              {plan.featured ? (
                <button type="button" data-offer-trigger data-offer-name={plan.label} data-offer-price={`${plan.price} ${plan.priceSub}${plan.priceMonthly ? ` · ${plan.priceMonthly}` : ''}`} class="block text-center w-full px-6 py-3 bg-white text-[var(--color-cta)] font-bold rounded-xl hover:bg-slate-100 transition-colors duration-200 active:scale-[0.97] text-sm cursor-pointer">{plan.cta}</button>
              ) : (
                <Button data-offer-trigger data-offer-name={plan.label} data-offer-price={`${plan.price} ${plan.priceSub}${plan.priceMonthly ? ` · ${plan.priceMonthly}` : ''}`} variant={plan.ctaVariant} class="w-full mt-auto">{plan.cta}</Button>
              )}
            </article>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── PANNEAU : SITE VITRINE ─────────────────────────── -->
  <div id="panel-web" class="formula-panel bg-white scroll-mt-6" hidden>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="text-center max-w-2xl mx-auto mb-12 panel-head">
        <h2 class="text-3xl font-extrabold text-[var(--color-primary)] mb-3">Votre site web</h2>
        <p class="text-base text-[var(--color-text-muted)]">
          Moderne, rapide et bien visible sur Google. Livré en 1 à 2 semaines, prêt à l'emploi.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        {webPlans.map((plan) => (
          <div class="formula-col flex">
            <article class={`pricing-card tilt-card group ${plan.featured ? 'pricing-card--featured' : ''}`}>
              {plan.badge && <span class="pricing-badge">{plan.badge}</span>}
              <div class={`pricing-icon ${plan.featured ? 'pricing-icon--featured' : ''}`}>
                <Fragment set:html={plan.icon} />
              </div>
              <span class={`for-who ${plan.featured ? 'for-who--featured' : ''}`}>{plan.forWho}</span>
              <h3 class={`text-xl font-bold mb-1 ${plan.featured ? 'text-white' : 'text-[var(--color-primary)]'}`}>{plan.label}</h3>
              <p class={`text-sm mb-5 leading-relaxed ${plan.featured ? 'text-white/60' : 'text-[var(--color-text-muted)]'}`}>{plan.sublabel}</p>
              <div class="mb-6">
                <div class="flex items-baseline gap-1.5">
                  <span class={`text-4xl font-extrabold ${plan.featured ? 'text-white' : 'text-[var(--color-primary)]'}`}>{plan.price}</span>
                  <span class={`text-sm ${plan.featured ? 'text-white/50' : 'text-[var(--color-text-muted)]'}`}>{plan.priceSub}</span>
                </div>
              </div>
              <ul class="space-y-3 mb-8 flex-1">
                {plan.items.map(item => (
                  <li class={`flex items-start gap-3 text-sm ${plan.featured ? 'text-white/85' : 'text-[var(--color-secondary)]'}`}>
                    <span class={`check ${plan.featured ? 'check--featured' : ''}`}>
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                      </svg>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
              {plan.featured ? (
                <button type="button" data-offer-trigger data-offer-name={plan.label} data-offer-price={`${plan.price} ${plan.priceSub}${plan.priceMonthly ? ` · ${plan.priceMonthly}` : ''}`} class="block text-center w-full px-6 py-3 bg-white text-[var(--color-cta)] font-bold rounded-xl hover:bg-slate-100 transition-colors duration-200 active:scale-[0.97] text-sm cursor-pointer">{plan.cta}</button>
              ) : (
                <Button data-offer-trigger data-offer-name={plan.label} data-offer-price={`${plan.price} ${plan.priceSub}${plan.priceMonthly ? ` · ${plan.priceMonthly}` : ''}`} variant={plan.ctaVariant} class="w-full mt-auto">{plan.cta}</Button>
              )}
            </article>
          </div>
        ))}
      </div>

      <div class="mt-8 flex items-center justify-center gap-2">
        <svg class="w-4 h-4 text-[var(--color-cta)] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm text-[var(--color-text-muted)]">
          Besoin qu'on s'occupe de tout au fil du temps ? Maintenance à <span class="font-semibold text-[var(--color-secondary)]">29€/mois</span>, en option.
        </p>
      </div>
    </div>
  </div>

  <!-- séparation visuelle sous le sélecteur -->
  <div class="bg-[var(--color-background)] pb-12"></div>

  <!-- ── MÉTHODE EN 5 ÉTAPES ───────────────────────────── -->
  <section class="py-24 bg-white relative overflow-hidden">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3">Comment ça se passe</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[var(--color-primary)] leading-tight mb-4">
          De votre premier appel<br/>à votre autonomie complète
        </h2>
        <p class="text-base text-[var(--color-text-muted)] max-w-xl mx-auto">
          Une méthode en 5 étapes, simple et transparente. Vous savez toujours où vous en êtes.
        </p>
      </div>

      <div class="relative">
        <div class="hidden lg:block absolute top-9 left-[10%] right-[10%] h-0.5 bg-[var(--color-border)] rounded-full overflow-hidden" aria-hidden="true">
          <div id="process-line" class="h-full w-0 bg-gradient-to-r from-[var(--color-cta)] to-[var(--color-accent)] rounded-full transition-[width] duration-[1400ms] ease-out"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-8 gap-y-12">
          {steps.map((s, i) => (
            <div class={`group text-center reveal reveal-delay-${(i + 1) * 100}`}>
              <div class="relative w-[72px] h-[72px] mx-auto mb-6">
                <div class="absolute inset-0 rounded-2xl bg-white border border-[var(--color-border)] flex items-center justify-center
                            transition-all duration-300 z-10
                            group-hover:bg-[var(--color-cta)] group-hover:border-[var(--color-cta)] group-hover:-translate-y-1"
                     style="box-shadow: var(--shadow-sm);">
                  <span class="text-[var(--color-cta)] transition-colors duration-300 group-hover:text-white">
                    <Fragment set:html={s.icon} />
                  </span>
                </div>
                <span class="absolute -top-2 -right-1 z-20 w-7 h-7 rounded-full bg-[var(--color-primary)] text-white
                             text-xs font-bold flex items-center justify-center
                             border-2 border-white transition-transform duration-300 group-hover:scale-110">
                  {s.num}
                </span>
              </div>
              <h3 class="text-base font-bold text-[var(--color-primary)] mb-2">{s.title}</h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ PRIX ──────────────────────────────────────── -->
  <section class="py-24 bg-[var(--color-background)] relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50" aria-hidden="true"
         style="background-image: radial-gradient(rgba(67,56,202,0.05) 1px, transparent 1px); background-size: 30px 30px;"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-[var(--color-cta)] font-semibold text-xs uppercase tracking-[0.18em] mb-3">Questions fréquentes</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[var(--color-primary)] leading-tight">
          Tout ce qu'on vous demande<br/>avant de se lancer
        </h2>
      </div>

      <div class="space-y-3">
        {faqs.map((faq, i) => (
          <div class={`faq-item bg-white rounded-2xl border border-[var(--color-border)] overflow-hidden reveal reveal-delay-${Math.min((i + 1) * 100, 300)}`} style="box-shadow: var(--shadow-sm);">
            <button
              type="button"
              class="faq-trigger w-full flex items-center justify-between gap-4 text-left px-6 py-5
                     focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-[var(--color-cta)]"
              aria-expanded="false"
            >
              <span class="font-bold text-[var(--color-primary)] text-sm sm:text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[var(--color-cta)] flex-shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-panel grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out">
              <div class="overflow-hidden">
                <p class="px-6 pb-5 text-sm text-[var(--color-text-muted)] leading-relaxed">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────── -->
  <section class="py-20 relative overflow-hidden" style="background: linear-gradient(135deg, #1A1A2E 0%, #2D1F50 50%, #1A1A2E 100%);">
    <div class="absolute inset-0 pointer-events-none opacity-25"
         style="background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 22px 22px;"
         aria-hidden="true"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-5 leading-tight">
        Pas sûr de quelle formule choisir ?
      </h2>
      <p class="text-base text-slate-300 mb-8 leading-relaxed">
        On en parle ensemble — appel gratuit de 30 minutes, sans engagement.
        On vous dit honnêtement ce qui vous convient le mieux.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Réserver un appel gratuit
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </Button>
    </div>
  </section>

  <script>
    /* ── Bascule des panneaux de formules ──────────────── */
    const pathCards = document.querySelectorAll<HTMLButtonElement>('.path-card');
    const hint = document.getElementById('select-hint');

    pathCards.forEach((card) => {
      card.addEventListener('click', () => {
        const targetId = card.dataset.target;
        if (!targetId) return;
        const panel = document.getElementById(targetId);
        if (!panel) return;

        const willOpen = card.getAttribute('aria-expanded') !== 'true';

        // Réinitialise toutes les cartes + panneaux
        pathCards.forEach((c) => c.setAttribute('aria-expanded', 'false'));
        document.querySelectorAll('.formula-panel').forEach((p) => {
          p.classList.remove('is-active');
          p.setAttribute('hidden', '');
        });

        if (willOpen) {
          card.setAttribute('aria-expanded', 'true');
          panel.removeAttribute('hidden');
          // force reflow pour (re)lancer l'animation
          void (panel as HTMLElement).offsetWidth;
          panel.classList.add('is-active');
          if (hint) hint.style.display = 'none';
          // scroll doux vers le panneau (via Lenis si dispo, sinon natif)
          setTimeout(() => {
            const lenis = (window as any).lenis;
            if (lenis) lenis.scrollTo(panel, { offset: -24 });
            else panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 60);
        } else {
          if (hint) hint.style.display = '';
          // remonte vers le sélecteur
          const lenis = (window as any).lenis;
          if (lenis) lenis.scrollTo(card, { offset: -120 });
          else card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    });

    /* ── Ligne de progression de la méthode ────────────── */
    const line = document.getElementById('process-line');
    if (line) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { line.style.width = '100%'; obs.disconnect(); } });
      }, { threshold: 0.4 });
      obs.observe(line);
    }

    /* ── Accordéon FAQ prix ────────────────────────────── */
    document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item   = trigger.closest('.faq-item');
        const panel  = item?.querySelector('.faq-panel') as HTMLElement | null;
        const icon   = trigger.querySelector('.faq-icon');
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', String(!isOpen));
        if (panel) panel.style.gridTemplateRows = isOpen ? '0fr' : '1fr';
        icon?.classList.toggle('rotate-180', !isOpen);
      });
    });
  </script>

  <!-- Mini-fenêtre de contact, ouverte au clic sur une offre -->
  <OfferModal />

</Layout>

<style>
  /* ── Cartes de chemin (sélecteur / toggle) ────────────── */
  .path-card {
    position: relative;
    display: block;
    width: 100%;
    text-align: left;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 2rem;
    overflow: hidden;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: transform 0.35s var(--ease-spring), box-shadow 0.35s var(--ease-smooth), border-color 0.25s;
  }
  .path-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-cta), var(--color-accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-smooth);
  }
  .path-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
    border-color: transparent;
  }
  .path-card:hover::before { transform: scaleX(1); }

  /* État sélectionné */
  .path-card[aria-expanded='true'] {
    border-color: var(--color-cta);
    box-shadow: var(--shadow-lg);
  }
  .path-card[aria-expanded='true']::before { transform: scaleX(1); }
  .path-card[aria-expanded='true'] .path-icon {
    color: #fff;
    background: linear-gradient(145deg, var(--color-cta), #1A1A2E);
  }

  .path-icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--color-cta);
    background: linear-gradient(145deg, rgba(67,56,202,0.12), rgba(6,182,212,0.10));
    transition: transform 0.35s var(--ease-spring), background 0.3s, color 0.3s;
  }
  .path-card:hover .path-icon { transform: scale(1.08) rotate(-4deg); }

  .path-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-cta);
  }
  .path-chevron { transition: transform 0.35s var(--ease-smooth); }
  .path-card[aria-expanded='true'] .path-chevron { transform: rotate(180deg); }
  /* libellé "Voir / Masquer" */
  .path-link-hide { display: none; }
  .path-card[aria-expanded='true'] .path-link-show { display: none; }
  .path-card[aria-expanded='true'] .path-link-hide { display: inline; }

  /* ── Panneau de formules (révélé au clic) ─────────────── */
  .formula-panel { display: none; }
  .formula-panel.is-active {
    display: block;
    animation: panelReveal 0.5s var(--ease-smooth) both;
  }
  @keyframes panelReveal {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* En-tête du panneau */
  .formula-panel.is-active .panel-head {
    animation: riseFade 0.5s var(--ease-smooth) both;
  }
  /* Cartes : entrée décalée */
  .formula-panel.is-active .formula-col {
    opacity: 0;
    animation: riseScale 0.55s var(--ease-spring) forwards;
  }
  .formula-panel.is-active .formula-col:nth-child(1) { animation-delay: 0.10s; }
  .formula-panel.is-active .formula-col:nth-child(2) { animation-delay: 0.20s; }
  .formula-panel.is-active .formula-col:nth-child(3) { animation-delay: 0.30s; }

  @keyframes riseFade {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes riseScale {
    from { opacity: 0; transform: translateY(22px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Cartes de prix ───────────────────────────────────── */
  .pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    /* transform piloté par .tilt-card (global) ; on ne transitionne ici que ce qu'il faut */
    transition: transform 0.2s var(--ease-smooth), box-shadow 0.35s var(--ease-smooth);
  }
  .pricing-card:hover {
    box-shadow: var(--shadow-lg);
  }
  .pricing-card--featured {
    background: linear-gradient(145deg, #4338CA 0%, #1A1A2E 100%);
    border-color: transparent;
    box-shadow: var(--shadow-xl);
  }
  .pricing-card--featured:hover {
    box-shadow: 0 24px 56px rgba(67,56,202,0.35);
  }

  .pricing-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--color-gold);
    color: var(--color-primary);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }

  .pricing-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--color-cta);
    background: rgba(67,56,202,0.10);
    transition: transform 0.35s var(--ease-spring);
  }
  .pricing-icon--featured {
    color: #fff;
    background: rgba(255,255,255,0.15);
  }
  .group:hover .pricing-icon { transform: scale(1.1) rotate(-4deg); }

  .for-who {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-cta);
    background: rgba(67,56,202,0.08);
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    margin-bottom: 0.75rem;
  }
  .for-who--featured {
    color: #fff;
    background: rgba(255,255,255,0.15);
  }

  .check {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--color-cta);
    background: rgba(67,56,202,0.10);
  }
  .check--featured {
    color: #fff;
    background: rgba(255,255,255,0.20);
  }

  /* ── Respect du reduced-motion ────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .formula-panel.is-active,
    .formula-panel.is-active .panel-head,
    .formula-panel.is-active .formula-col {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
